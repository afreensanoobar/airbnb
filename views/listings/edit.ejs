<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Wanderlust</title>
  </head>
  <body>
    <h3>Edit Listing:</h3>
    <form action="/listings/<%= listings._id %>?_method=PUT" method="POST">
      <label for="title">Title:</label>
      <input
        type="text"
        id="title"
        name="title"
        value="<%= listings.title %>"
        required
      /><br /><br />

      <label for="description">Description:</label><br />
      <textarea id="description" name="description" rows="4" cols="50" required>
<%= listings.description %></textarea
      ><br /><br />

      <label for="price">Price:</label>
      <input
        type="number"
        id="price"
        name="price"
        value="<%= listings.price %>"
        required
      /><br /><br />

      <label for="location">Location:</label>
      <input
        type="text"
        id="location"
        name="location"
        value="<%= listings.location %>"
        required
      /><br /><br />

      <label for="country">Country:</label>
      <input
        type="text"
        id="country"
        name="country"
        value="<%= listings.country %>"
        required
      /><br /><br />

      <button type="submit">Update Listing</button>
    </form>
  </body>
</html>
